# KAIROSKOP — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── GCP ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET_NAME=kairoskop-datalake-${GCP_PROJECT_ID}
BQ_DATASET=kairoskop
GOOGLE_APPLICATION_CREDENTIALS=credentials/sa-key.json

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_WIKI_PAGEVIEWS=wiki_pageviews
KAFKA_TOPIC_WIKI_CHANGES=wiki_changes
KAFKA_TOPIC_GDELT=gdelt_events
KAFKA_TOPIC_ARXIV=arxiv_papers

# ── Wikipedia ─────────────────────────────────────────────────────────
# No credentials required — Wikimedia APIs are public
WIKI_PAGEVIEWS_PROJECT=en.wikipedia
WIKI_PAGEVIEWS_ACCESS=all-access
WIKI_PAGEVIEWS_AGENT=all-agents
WIKI_SSE_URL=https://stream.wikimedia.org/v2/stream/recentchange

# ── GDELT ─────────────────────────────────────────────────────────────
# No credentials required
GDELT_POLL_INTERVAL_SECONDS=900

# ── arXiv ─────────────────────────────────────────────────────────────
# No credentials required
ARXIV_CATEGORIES=cs.AI,cs.LG,physics,q-bio,econ,stat
ARXIV_MAX_RESULTS_PER_CATEGORY=200

# ── Spark ─────────────────────────────────────────────────────────────
SPARK_MASTER=spark://localhost:7077
SPARK_CHECKPOINT_DIR=/tmp/checkpoints/kairoskop
SPARK_TRIGGER_INTERVAL=5 minutes
