# KAIROSKOP — .gitignore

# Environment variables (never commit)
.env
*.env

# GCP credentials (never commit)
credentials/
*.json
!bruin/.bruin.yml

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Spark checkpoints and logs
/tmp/
spark-warehouse/
derby.log
metastore_db/
*.log

# Terraform state (use remote backend in production)
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfplan

# Docker volumes
docker-volumes/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
